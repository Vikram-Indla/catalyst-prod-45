VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxtcXd0bGRwZmFjcnJsdmRubWxkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg4NTkwODEsImV4cCI6MjA5NDQzNTA4MX0.CITWnsiEJEd1B-G4RReYZdaTFbBNvw8NnM8OrRvDX8s

# Turns on "Create Kanban from filter" in the filter ⋯ menu.
VITE_ENABLE_FILTER_TO_KANBAN=true
# Turns on "Create Roadmap from filter" in the filter ⋯ menu (Feature 2).
VITE_ENABLE_FILTER_TO_ROADMAP=true
# Turns on "Create/Open dashboard from filter" in the filter ⋯ menu (Feature 3).
VITE_ENABLE_FILTER_TO_DASHBOARD=true
# Turns on "Copy WhatsApp summary" in the filter ⋯ menu (Feature 4 — AI-authored).
VITE_ENABLE_FILTER_WHATSAPP_AI_SUMMARY=true
# Voice Translate Dictation — double-space hotkey → Gemini AR/UR/HI→EN.
# Defaults OFF. Set to true + enable feature_flags.voice_dictation in DB to activate.
VITE_VOICE_DICTATION_ENABLED=false
