{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@atlaskit/icon/core/*": ["./src/types/atlaskit-icon-shim.d.ts"],
      "@atlaskit/icon/glyph/*": ["./src/types/atlaskit-icon-shim.d.ts"],
      "@atlaskit/icon/utility/*": ["./src/types/atlaskit-icon-shim.d.ts"],
      "@catylast/tokens": ["./packages/tokens/src/index.ts"],
      "@catylast/tokens/tokens.css": ["./packages/tokens/dist/tokens.css"],
      "@catylast/theme": ["./packages/theme/src/index.ts"],
      "@catylast/icons": ["./packages/icons/src/index.ts"],
      "@catylast/primitives": ["./packages/primitives/src/index.ts"],
      "@catylast/primitives/styles.css": ["./packages/primitives/dist/index.css"],
      "@catylast/card": ["./packages/card/src/index.ts"],
      "@catylast/card/styles.css": ["./packages/card/dist/index.css"],
      "@catylast/rich-editor": ["./packages/rich-editor/src/index.ts"],
      "@catylast/rich-editor/styles.css": ["./packages/rich-editor/dist/index.css"],
      "@catylast/dynamic-table": ["./packages/dynamic-table/src/index.ts"],
      "@catylast/dynamic-table/styles.css": ["./packages/dynamic-table/dist/index.css"]
    },
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "types": ["vitest/globals"],
    "useDefineForClassFields": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/_graveyard"
  ]
}
