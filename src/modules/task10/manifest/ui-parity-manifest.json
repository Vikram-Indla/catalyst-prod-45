    "apiBase": "/api/task10"
  },
  "navigation": {
    "topNavLabel": "TaskHub",
    "sidebarLabel": "Task10"
  },
  "pages": [
    {
      "name": "Landing",
      "route": "/taskhub/task10",
      "components": [
        "T10Header",
        "T10SearchBar",
        "T10FilterBar",
        "T10ListCard",
        "T10WeekHistoryToggle",
        "T10WeekHistoryItem",
        "T10DropdownMenu"
      ]
    },
    {
      "name": "WeekView",
      "route": "/taskhub/task10/list/:listId",
      "components": [
        "T10WeekHeader",
        "T10AIBanner",
        "T10QuickAdd",
        "T10PriorityCard",
        "T10BufferSection",
        "T10SidePanel"
      ]
    }
  ],
  "components": {
    "landing": [
      "T10Header",
      "T10SearchBar",
      "T10FilterButton",
      "T10ListCard",
      "T10WeekHistoryToggle",
      "T10WeekHistoryItem",
      "T10DropdownMenu"
    ],
    "weekView": [
      "T10WeekHeader",
      "T10AIBanner",
      "T10QuickAdd",
      "T10PriorityCard",
      "T10BufferSection",
      "T10RankBadge",
      "T10Checkbox"
    ],
    "sidePanel": [
      "T10SidePanel",
      "T10PanelDetailsTab",
      "T10PanelActivityTab"
    ],
    "modals": [
      "T10CreateListModal",
      "T10RenameListModal",
      "T10DeleteListModal",
      "T10CheckoutModal"
    ],
    "shared": [
      "T10Button",
      "T10Input",
      "T10Textarea",
      "T10Toast"
    ]
  },
  "cssTokens": {
    "colors": {
      "blue": "#2563eb",
      "blueDark": "#1d4ed8",
      "blue50": "#eff6ff",
      "purple": "#8b5cf6",
      "purpleDark": "#7c3aed",
      "purple50": "#f5f3ff",
      "success": "#10b981",
      "warning": "#f59e0b",
      "danger": "#ef4444"
    },
    "spacing": {
      "containerMaxWidth": "1100px",
      "cardPadding": "20px 24px",
      "panelWidth": "420px",
      "modalWidth": "520px"
    },
    "typography": {
      "fontFamily": "'Inter', -apple-system, sans-serif",
      "fontMono": "'SF Mono', Monaco, monospace"
    }
  },
  "uiParity": {
    "header": {
      "iconBox": {
        "size": "44x44px",
        "background": "#2563eb",
        "text": "10",
        "fontWeight": 800
      }
    },
    "listCard": {
      "padding": "20px 24px",
      "borderRadius": "12px",
      "idBadge": {
        "font": "mono",
        "background": "#eff6ff"
      },
      "progressBar": {
        "height": "6px",
        "fill": "#2563eb"
      }
    },
    "priorityCard": {
      "padding": "16px 18px",
      "rankBadge": {
        "size": "34x34px",
        "rank1to5": "linear-gradient(#2563eb, #1d4ed8)",
        "rank6to10": "#6b7280",
        "rank11plus": "dashed"
      },
      "checkbox": {
        "size": "30x30px",
        "checkedColor": "#10b981",
        "animation": "pop 0.3s"
      }
    },
    "aiBanner": {
      "theme": "PURPLE",
      "iconBorder": "2px solid #8b5cf6",
      "iconSize": "40x40px",
      "background": "#f5f3ff"
    },
    "sidePanel": {
      "width": "420px",
      "animation": "slide-in-right 0.25s"
    },
    "modals": {
      "width": "520px",
      "deleteConfirm": "GitHub-style name match"
    }
  },
  "database": {
    "tables": [
      "t10_lists",
      "t10_weeks",
      "t10_items",
      "t10_activity",
      "t10_ai_suggestions"
    ]
  },
  "verification": {
    "prompt0": {
      "complete": true,
      "files": [
        "/src/modules/task10/constants/module.ts",
        "/src/modules/task10/constants/navigation.ts",
        "/src/modules/task10/constants/ui-tokens.ts",
        "/src/modules/task10/types/index.ts",
        "/src/modules/task10/types/list.types.ts",
        "/src/modules/task10/types/week.types.ts",
        "/src/modules/task10/types/item.types.ts",
        "/src/modules/task10/types/activity.types.ts",
        "/src/modules/task10/types/ai-suggestion.types.ts",
        "/src/modules/task10/styles/task10.scoped.css",
        "/src/modules/task10/manifest/ui-parity-manifest.json"
      ]
    }
  }
}
