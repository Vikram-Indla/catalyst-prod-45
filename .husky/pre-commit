#!/bin/sh

# Pre-commit hook: Design System Audit
# 1) Self-test verifies the scanners themselves haven't regressed.
# 2) Audit runs against src/ and reports the count.
# Both are informational locally. CI gates them as blocking.

echo "🧪 Audit self-test (verifies scanners catch what they claim)…"
node design-governance/scripts/self-test.mjs 2>&1 | tail -5 || true

# --- BLOCKING ratchets (CAT-ADS-COMPLIANCE-20260627-001) -----------------
# Both ratchets fail ONLY when a count rises above its committed baseline, so
# existing debt never blocks — only NEW violations do.
echo ""
echo "🎨 ADS color ratchet (blocks on NEW hard-coded colors)…"
node scripts/ads-color-gate.cjs || exit 1

echo ""
echo "🎨 ADS fallback-hex ratchet (blocks on NEW var(--ds-*, #hex) / token('x','#hex'))…"
node scripts/ads-fallback-hex-gate.cjs || exit 1

# Runs the design-governance audit ONCE and gates per category
# (tokens/typography/spacing/fontImports) vs design-governance/audit-baseline.json.
echo ""
echo "📐 ADS audit ratchet (blocks on NEW tokens/typography/spacing violations)…"
node scripts/ads-audit-gate.cjs || exit 1

# CRE chokepoint gate (.claude/skills/cre/SKILL.md): create/link/parent
# surfaces must keep querying @/lib/catalyst-rules — no hardcoded type lists.
echo ""
echo "⚖️  CRE chokepoint gate (create/link/parent surfaces query the rules engine)…"
node scripts/cre-chokepoint-gate.cjs || exit 1
