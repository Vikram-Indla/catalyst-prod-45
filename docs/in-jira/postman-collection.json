{
  "info": {
    "_postman_id": "catalyst-jira-api",
    "name": "Catalyst In-Jira API",
    "description": "Jira-compatible REST API facade over Catalyst services.\n\nAll endpoints require Bearer token authentication.\n\n## Setup\n1. Get a valid auth token from your Supabase project\n2. Set the `auth_token` collection variable\n3. Set the `base_url` to your function endpoint",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://stcpycushiccfvrqwipw.supabase.co/functions/v1/jira-api",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "YOUR_SUPABASE_AUTH_TOKEN",
      "type": "string"
    },
    {
      "key": "tenant_id",
      "value": "default-tenant",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Issues",
      "description": "Issue management endpoints",
      "item": [
        {
          "name": "Create Issue",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"project\": {\n      \"key\": \"PROJ\"\n    },\n    \"summary\": \"Test issue summary\",\n    \"description\": {\n      \"type\": \"doc\",\n      \"version\": 1,\n      \"content\": [\n        {\n          \"type\": \"paragraph\",\n          \"content\": [\n            {\n              \"type\": \"text\",\n              \"text\": \"Description text\"\n            }\n          ]\n        }\n      ]\n    },\n    \"issuetype\": {\n      \"name\": \"Story\"\n    },\n    \"priority\": {\n      \"name\": \"Medium\"\n    },\n    \"labels\": [\"test\", \"api\"]\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/rest/api/3/issue?tenantId={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["rest", "api", "3", "issue"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenant_id}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Issue",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/rest/api/3/issue/PROJ-1?tenantId={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["rest", "api", "3", "issue", "PROJ-1"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenant_id}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Issue",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"summary\": \"Updated summary\",\n    \"priority\": {\n      \"name\": \"High\"\n    },\n    \"labels\": [\"updated\", \"urgent\"]\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/rest/api/3/issue/PROJ-1?tenantId={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["rest", "api", "3", "issue", "PROJ-1"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenant_id}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Assignee",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": \"user-uuid-here\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/rest/api/3/issue/PROJ-1/assignee?tenantId={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["rest", "api", "3", "issue", "PROJ-1", "assignee"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenant_id}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Search",
      "description": "Search endpoints",
      "item": [
        {
          "name": "Search Issues (Basic)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jql\": \"project = PROJ ORDER BY created DESC\",\n  \"startAt\": 0,\n  \"maxResults\": 50\n}"
            },
            "url": {
              "raw": "{{base_url}}/rest/api/3/search?tenantId={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["rest", "api", "3", "search"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenant_id}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Search Issues (With Filters)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jql\": \"project = PROJ AND status = \\\"In Progress\\\" ORDER BY priority DESC\",\n  \"startAt\": 0,\n  \"maxResults\": 25\n}"
            },
            "url": {
              "raw": "{{base_url}}/rest/api/3/search?tenantId={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["rest", "api", "3", "search"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenant_id}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
