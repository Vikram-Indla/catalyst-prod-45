            "method": "GET",
            "url": {
              "raw": "{{base_url}}/rest/agile/1.0/board/:boardId/sprint?tenantId={{tenant_id}}&state=active",
              "host": ["{{base_url}}"],
              "path": ["rest", "agile", "1.0", "board", ":boardId", "sprint"],
              "variable": [
