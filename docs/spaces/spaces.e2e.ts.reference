test.describe('Space Members', () => {
  test.beforeEach(async ({ page }) => {
    await loginAs(page, 'owner');
    await page.goto(`${BASE_URL}/spaces/test-space-1/settings/access`);
  });

  test('MEMBERS-001: View members list', async ({ page }) => {
    await expect(page.locator('[data-testid="members-table"]')).toBeVisible();
    await expect(page.locator('[data-testid="member-row"]').first()).toBeVisible();
  });

  test('MEMBERS-002: Add member to space', async ({ page }) => {
    await page.click('[data-testid="add-member-button"]');
    await page.waitForSelector('[role="dialog"]');
    
    await page.fill('[data-testid="user-search-input"]', 'new.member@catalyst.gov.sa');
    await page.click('[data-testid="user-option"]:first-child');
    await page.selectOption('[data-testid="role-select"]', 'member');
    await page.click('[data-testid="add-member-submit"]');
    
    await expect(page.locator('[data-testid="toast"]')).toContainText('added');
    await expect(page.locator('[data-testid="members-table"]')).toContainText('new.member');
  });

  test('MEMBERS-003: Change member role', async ({ page }) => {
    const memberRow = page.locator('[data-testid="member-row"]:has-text("member@catalyst")');
    await memberRow.locator('[data-testid="role-select"]').selectOption('lead');
    
    await expect(page.locator('[data-testid="toast"]')).toContainText('updated');
  });

  test('MEMBERS-004: Remove member from space', async ({ page }) => {
    const memberRow = page.locator('[data-testid="member-row"]:has-text("viewer@catalyst")');
    await memberRow.locator('[data-testid="remove-member-button"]').click();
    await page.click('[data-testid="confirm-remove-button"]');
    
    await expect(page.locator('[data-testid="toast"]')).toContainText('removed');
    await expect(page.locator('[data-testid="members-table"]')).not.toContainText('viewer@catalyst');
  });
});

// ============================================================================
// AUTHORIZATION TESTS
