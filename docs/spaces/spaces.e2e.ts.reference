test.describe('Authorization (RBAC)', () => {
  test('RBAC-001: Viewer cannot access settings', async ({ page }) => {
    await loginAs(page, 'viewer');
    await page.goto(`${BASE_URL}/spaces/test-space-1/settings`);
    
    // Should redirect or show access denied
    await expect(page.locator('[data-testid="access-denied"]')).toBeVisible();
  });

  test('RBAC-002: Member cannot delete space', async ({ page }) => {
    await loginAs(page, 'member');
    await page.goto(`${BASE_URL}/spaces/test-space-1`);
    
    // Delete option should not be visible
    await page.click('[data-testid="space-menu-button"]');
    await expect(page.locator('[data-testid="delete-space-option"]')).not.toBeVisible();
  });

  test('RBAC-003: Non-admin cannot access admin panel', async ({ page }) => {
    await loginAs(page, 'owner');
    await page.goto(`${BASE_URL}/admin/spaces`);
    
    await expect(page).toHaveURL(/\/spaces/);
    // OR
    // await expect(page.locator('[data-testid="access-denied"]')).toBeVisible();
  });

  test('RBAC-004: Admin can access all spaces', async ({ page }) => {
    await loginAs(page, 'admin');
    await page.goto(`${BASE_URL}/admin/spaces`);
    
    await expect(page.locator('[data-testid="admin-spaces-table"]')).toBeVisible();
    // Should see more spaces than regular user
    const spaceCount = await page.locator('[data-testid="space-row"]').count();
    expect(spaceCount).toBeGreaterThan(0);
  });
});

// ============================================================================
// KANBAN BOARD TESTS
// ============================================================================

test.describe('Kanban Board', () => {
  test.beforeEach(async ({ page }) => {
    await loginAs(page, 'owner');
    await page.goto(`${BASE_URL}/spaces/test-space-1/board`);
  });

  test('BOARD-001: Board renders all columns', async ({ page }) => {
    await expect(page.locator('[data-testid="column-todo"]')).toBeVisible();
    await expect(page.locator('[data-testid="column-in-progress"]')).toBeVisible();
    await expect(page.locator('[data-testid="column-done"]')).toBeVisible();
  });

  test('BOARD-002: Drag item between columns', async ({ page }) => {
    const todoColumn = page.locator('[data-testid="column-todo"]');
    const inProgressColumn = page.locator('[data-testid="column-in-progress"]');
    const item = todoColumn.locator('[data-testid="board-item"]:first-child');
    
    const itemId = await item.getAttribute('data-item-id');
    
    await item.dragTo(inProgressColumn);
    
    // Verify item moved
    await expect(inProgressColumn.locator(`[data-item-id="${itemId}"]`)).toBeVisible();
    await expect(todoColumn.locator(`[data-item-id="${itemId}"]`)).not.toBeVisible();
  });

  test('BOARD-003: Add item to column', async ({ page }) => {
    const todoColumn = page.locator('[data-testid="column-todo"]');
    await todoColumn.locator('[data-testid="add-item-button"]').click();
    
    await page.fill('[data-testid="quick-add-input"]', 'New Test Task');
    await page.keyboard.press('Enter');
    
    await expect(todoColumn.locator('[data-testid="board-item"]')).toContainText('New Test Task');
  });
});

