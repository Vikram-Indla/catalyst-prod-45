// ============================================================================
// FORM VALIDATION TESTS
// ============================================================================

test.describe('Form Validation', () => {
  test.beforeEach(async ({ page }) => {
    await loginAs(page, 'owner');
  });

  test('VAL-001: Space name validation', async ({ page }) => {
    await page.click('[data-testid="create-space-button"]');
    await page.waitForSelector('[role="dialog"]');
    
    // Too short
    await page.fill('[data-testid="space-name-input"]', 'ab');
    await page.click('[data-testid="space-key-input"]'); // Blur
    await expect(page.locator('[data-testid="name-error"]')).toContainText('3 characters');
    
    // Valid
    await page.fill('[data-testid="space-name-input"]', 'Valid Name');
    await page.click('[data-testid="space-key-input"]'); // Blur
    await expect(page.locator('[data-testid="name-error"]')).not.toBeVisible();
  });

  test('VAL-002: Space key validation', async ({ page }) => {
    await page.click('[data-testid="create-space-button"]');
    await page.waitForSelector('[role="dialog"]');
    
    // Invalid characters
    await page.fill('[data-testid="space-key-input"]', 'AB-C');
    await page.click('[data-testid="space-name-input"]'); // Blur
    await expect(page.locator('[data-testid="key-error"]')).toContainText('alphanumeric');
    
    // Too long
    await page.fill('[data-testid="space-key-input"]', 'VERYLONGKEY');
    await page.click('[data-testid="space-name-input"]'); // Blur
    await expect(page.locator('[data-testid="key-error"]')).toContainText('10 characters');
  });

  test('VAL-003: Version date validation', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces/test-space-1/settings/versions`);
    await page.click('[data-testid="add-version-button"]');
    
    await page.fill('[data-testid="version-name-input"]', 'v1.0.0');
    await page.fill('[data-testid="start-date-input"]', '2025-06-01');
    await page.fill('[data-testid="end-date-input"]', '2025-05-01'); // Before start
    
    await page.click('[data-testid="create-version-submit"]');
    await expect(page.locator('[data-testid="date-error"]')).toContainText('after start');
  });
});

// ============================================================================
// ACCESSIBILITY TESTS
// ============================================================================

test.describe('Accessibility', () => {
  test.beforeEach(async ({ page }) => {
    await loginAs(page, 'owner');
  });

  test('A11Y-001: Spaces directory page', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces`);
    
    const results = await new AxeBuilder({ page })
      .withTags(['wcag2a', 'wcag2aa'])
      .analyze();
    
    expect(results.violations).toEqual([]);
  });

  test('A11Y-002: Space detail page', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces/test-space-1`);
    
    const results = await new AxeBuilder({ page })
      .withTags(['wcag2a', 'wcag2aa'])
      .analyze();
    
    expect(results.violations).toEqual([]);
  });

  test('A11Y-003: Create space modal', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces`);
    await page.click('[data-testid="create-space-button"]');
    await page.waitForSelector('[role="dialog"]');
    
    const results = await new AxeBuilder({ page })
      .withTags(['wcag2a', 'wcag2aa'])
      .analyze();
    
    expect(results.violations).toEqual([]);
  });

  test('A11Y-004: Keyboard navigation', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces`);
    
    // Tab through interactive elements
    await page.keyboard.press('Tab');
    await expect(page.locator(':focus')).toBeVisible();
    
    // Navigate to first space card
    const spaceCard = page.locator('[data-testid="space-card"]:first-child');
    await spaceCard.focus();
    await page.keyboard.press('Enter');
    
    await expect(page).toHaveURL(/\/spaces\/[\w-]+/);
  });

  test('A11Y-005: Modal focus trap', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces`);
    await page.click('[data-testid="create-space-button"]');
    await page.waitForSelector('[role="dialog"]');
    
    // Tab through all elements - should stay in modal
    for (let i = 0; i < 20; i++) {
      await page.keyboard.press('Tab');
      const focusedElement = page.locator(':focus');
      const modal = page.locator('[role="dialog"]');
      
      // Verify focus is within modal
      await expect(focusedElement).toBeVisible();
      const isInModal = await focusedElement.evaluate((el, modalEl) => {
        return modalEl.contains(el);
      }, await modal.elementHandle());
      expect(isInModal).toBe(true);
    }
  });
});

// ============================================================================
// PERFORMANCE TESTS
// ============================================================================

test.describe('Performance', () => {
  test('PERF-001: Spaces page load time', async ({ page }) => {
    await loginAs(page, 'owner');
    
    const startTime = Date.now();
    await page.goto(`${BASE_URL}/spaces`);
    await page.waitForSelector('[data-testid="space-card"]:first-child');
    const loadTime = Date.now() - startTime;
    
    expect(loadTime).toBeLessThan(3000); // 3 seconds max
  });

  test('PERF-002: Space detail page load time', async ({ page }) => {
    await loginAs(page, 'owner');
    
    const startTime = Date.now();
    await page.goto(`${BASE_URL}/spaces/test-space-1`);
    await page.waitForSelector('[data-testid="space-summary"]');
    const loadTime = Date.now() - startTime;
    
    expect(loadTime).toBeLessThan(2000); // 2 seconds max
  });

  test('PERF-003: No memory leaks on navigation', async ({ page }) => {
    await loginAs(page, 'owner');
    
    const getHeapSize = async () => {
      const metrics = await page.evaluate(() => {
        return (performance as any).memory?.usedJSHeapSize || 0;
      });
      return metrics;
    };
    
    const initialHeap = await getHeapSize();
    
    // Navigate back and forth multiple times
    for (let i = 0; i < 10; i++) {
      await page.goto(`${BASE_URL}/spaces`);
      await page.goto(`${BASE_URL}/spaces/test-space-1`);
      await page.goto(`${BASE_URL}/spaces/test-space-1/board`);
    }
    
    // Force garbage collection if available
    await page.evaluate(() => {
      if ((window as any).gc) (window as any).gc();
    });
    
    const finalHeap = await getHeapSize();
    
    // Heap should not grow more than 50% (allowing for normal variation)
    if (initialHeap > 0) {
      expect(finalHeap).toBeLessThan(initialHeap * 1.5);
    }
  });
});

// ============================================================================
// ERROR HANDLING TESTS
// ============================================================================

test.describe('Error Handling', () => {
  test.beforeEach(async ({ page }) => {
    await loginAs(page, 'owner');
  });

  test('ERR-001: Network error shows toast', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces`);
    
    // Simulate network failure
    await page.route('**/api/spaces**', route => route.abort());
    
    await page.reload();
    
    await expect(page.locator('[data-testid="error-toast"]')).toBeVisible();
  });

  test('ERR-002: 404 error shows not found page', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces/non-existent-id`);
    
    await expect(page.locator('[data-testid="not-found-page"]')).toBeVisible();
    await expect(page.locator('[data-testid="back-to-spaces-link"]')).toBeVisible();
  });

  test('ERR-003: Form submission error shows error message', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces`);
    await page.click('[data-testid="create-space-button"]');
    
    // Mock API error
    await page.route('**/api/spaces', route => 
      route.fulfill({ status: 500, body: JSON.stringify({ error: 'Server error' }) })
    );
    
    await page.fill('[data-testid="space-name-input"]', 'Test');
    await page.fill('[data-testid="space-key-input"]', 'TST');
    await page.selectOption('[data-testid="space-type-select"]', 'scrum');
    await page.click('[data-testid="create-space-submit"]');
    
    await expect(page.locator('[data-testid="error-toast"]')).toContainText('error');
  });
});

// ============================================================================
// SECURITY TESTS
// ============================================================================

test.describe('Security', () => {
  test('SEC-001: XSS in space name is escaped', async ({ page }) => {
    await loginAs(page, 'owner');
    
    const xssPayload = '<script>alert("xss")</script>';
    
    await page.click('[data-testid="create-space-button"]');
    await page.fill('[data-testid="space-name-input"]', xssPayload);
    await page.fill('[data-testid="space-key-input"]', 'XSS');
    await page.selectOption('[data-testid="space-type-select"]', 'scrum');
    await page.click('[data-testid="create-space-submit"]');
    
    // Should show escaped text, not execute script
    await expect(page.locator('h1')).toContainText('script');
    
    // No alert should have been triggered (would throw)
    const dialogPromise = page.waitForEvent('dialog', { timeout: 1000 }).catch(() => null);
    expect(await dialogPromise).toBeNull();
  });

  test('SEC-002: IDOR - Cannot access others private space', async ({ page }) => {
    await loginAs(page, 'member');
    
    // Try to access a private space owned by another user
    await page.goto(`${BASE_URL}/spaces/private-space-other-user`);
    
    // Should see access denied or 404
    const accessDenied = page.locator('[data-testid="access-denied"]');
    const notFound = page.locator('[data-testid="not-found-page"]');
    
    const isAccessDenied = await accessDenied.isVisible().catch(() => false);
    const isNotFound = await notFound.isVisible().catch(() => false);
    
    expect(isAccessDenied || isNotFound).toBe(true);
  });
});

// ============================================================================
// SMOKE TESTS (Quick CI/CD)
// ============================================================================

test.describe('Smoke Tests', () => {
  test('SMOKE-001: Homepage loads', async ({ page }) => {
    await page.goto(BASE_URL);
    await expect(page).toHaveTitle(/Catalyst/);
  });

  test('SMOKE-002: Login works', async ({ page }) => {
    await loginAs(page, 'owner');
    await expect(page).toHaveURL(/\/spaces/);
  });

  test('SMOKE-003: Spaces list loads', async ({ page }) => {
    await loginAs(page, 'owner');
    await page.goto(`${BASE_URL}/spaces`);
    await expect(page.locator('[data-testid="spaces-directory"]')).toBeVisible();
  });

  test('SMOKE-004: Create space modal opens', async ({ page }) => {
    await loginAs(page, 'owner');
    await page.goto(`${BASE_URL}/spaces`);
    await page.click('[data-testid="create-space-button"]');
    await expect(page.locator('[role="dialog"]')).toBeVisible();
  });

  test('SMOKE-005: Board view renders', async ({ page }) => {
    await loginAs(page, 'owner');
    await page.goto(`${BASE_URL}/spaces/test-space-1/board`);
    await expect(page.locator('[data-testid="space-board"]')).toBeVisible();
  });
});
