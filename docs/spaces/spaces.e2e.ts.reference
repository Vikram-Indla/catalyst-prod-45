/**
 * CATALYST SPACES MODULE - E2E TEST SUITE
 * Playwright Tests for Critical Paths
 * 
 * Run: npx playwright test spaces.e2e.ts
 */

import { test, expect, Page } from '@playwright/test';
import AxeBuilder from '@axe-core/playwright';

// ============================================================================
// TEST CONFIGURATION
// ============================================================================

const BASE_URL = process.env.BASE_URL || 'http://localhost:5173';

const TEST_USERS = {
  admin: { email: 'admin@catalyst.gov.sa', password: 'AdminPass123!' },
  owner: { email: 'owner@catalyst.gov.sa', password: 'OwnerPass123!' },
  member: { email: 'member@catalyst.gov.sa', password: 'MemberPass123!' },
  viewer: { email: 'viewer@catalyst.gov.sa', password: 'ViewerPass123!' },
};

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

async function loginAs(page: Page, role: keyof typeof TEST_USERS) {
  const user = TEST_USERS[role];
  await page.goto(`${BASE_URL}/login`);
  await page.fill('[data-testid="email-input"]', user.email);
  await page.fill('[data-testid="password-input"]', user.password);
  await page.click('[data-testid="login-button"]');
  await page.waitForURL('**/spaces**');
}

async function createTestSpace(page: Page, name: string, key: string) {
  await page.click('[data-testid="create-space-button"]');
  await page.waitForSelector('[role="dialog"]');
  await page.fill('[data-testid="space-name-input"]', name);
  await page.fill('[data-testid="space-key-input"]', key);
  await page.selectOption('[data-testid="space-type-select"]', 'scrum');
  await page.click('[data-testid="create-space-submit"]');
  await page.waitForURL(/\/spaces\/[\w-]+/);
}

async function deleteTestSpace(page: Page, spaceName: string) {
  await page.click('[data-testid="space-menu-button"]');
  await page.click('[data-testid="delete-space-option"]');
  await page.fill('[data-testid="confirm-delete-input"]', spaceName);
  await page.click('[data-testid="confirm-delete-button"]');
}

// ============================================================================
// AUTHENTICATION TESTS
// ============================================================================

test.describe('Authentication', () => {
  test('AUTH-001: Access /spaces without token redirects to login', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces`);
    await expect(page).toHaveURL(/\/login/);
  });

  test('AUTH-002: Valid login grants access to spaces', async ({ page }) => {
    await loginAs(page, 'owner');
    await expect(page).toHaveURL(/\/spaces/);
    await expect(page.locator('[data-testid="spaces-directory"]')).toBeVisible();
  });

  test('AUTH-003: Logout removes access', async ({ page }) => {
    await loginAs(page, 'owner');
    await page.click('[data-testid="user-menu"]');
    await page.click('[data-testid="logout-button"]');
    await expect(page).toHaveURL(/\/login/);
    
    // Try to access protected route
    await page.goto(`${BASE_URL}/spaces`);
    await expect(page).toHaveURL(/\/login/);
  });
});

// ============================================================================
// SPACE CRUD TESTS
// ============================================================================

test.describe('Space CRUD Operations', () => {
  test.beforeEach(async ({ page }) => {
    await loginAs(page, 'owner');
  });

  test('CRUD-001: Create space with valid data', async ({ page }) => {
    const spaceName = `Test Space ${Date.now()}`;
    const spaceKey = `TS${Date.now().toString().slice(-3)}`;

    await createTestSpace(page, spaceName, spaceKey);
    
    await expect(page.locator('h1')).toContainText(spaceName);
    await expect(page.locator('[data-testid="space-key-badge"]')).toContainText(spaceKey.toUpperCase());
    
    // Cleanup
    await deleteTestSpace(page, spaceName);
  });

  test('CRUD-002: Create space form validation', async ({ page }) => {
    await page.click('[data-testid="create-space-button"]');
    await page.waitForSelector('[role="dialog"]');
    
    // Submit empty form
    await page.click('[data-testid="create-space-submit"]');
    
    await expect(page.locator('[data-testid="name-error"]')).toContainText('required');
    await expect(page.locator('[data-testid="key-error"]')).toContainText('required');
  });

  test('CRUD-003: Create space with duplicate key shows error', async ({ page }) => {
    const spaceName = `Dupe Test ${Date.now()}`;
    
    await page.click('[data-testid="create-space-button"]');
    await page.waitForSelector('[role="dialog"]');
    await page.fill('[data-testid="space-name-input"]', spaceName);
    await page.fill('[data-testid="space-key-input"]', 'TSA'); // Existing key
    await page.selectOption('[data-testid="space-type-select"]', 'scrum');
    await page.click('[data-testid="create-space-submit"]');
    
    await expect(page.locator('[data-testid="key-error"]')).toContainText('already exists');
  });

  test('CRUD-004: View space list', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces`);
    
    await expect(page.locator('[data-testid="spaces-directory"]')).toBeVisible();
    await expect(page.locator('[data-testid="space-card"]').first()).toBeVisible();
  });

  test('CRUD-005: View space details', async ({ page }) => {
    await page.goto(`${BASE_URL}/spaces`);
    await page.click('[data-testid="space-card"]:first-child');
    
    await expect(page.locator('[data-testid="space-summary"]')).toBeVisible();
    await expect(page.locator('[data-testid="space-stats"]')).toBeVisible();
  });

  test('CRUD-006: Update space name', async ({ page }) => {
    const spaceName = `Update Test ${Date.now()}`;
    const spaceKey = `UT${Date.now().toString().slice(-3)}`;
    const newName = `Updated ${Date.now()}`;

    await createTestSpace(page, spaceName, spaceKey);
    
    await page.click('[data-testid="settings-tab"]');
    await page.fill('[data-testid="space-name-input"]', newName);
    await page.click('[data-testid="save-settings-button"]');
    
    await expect(page.locator('[data-testid="toast"]')).toContainText('saved');
    await expect(page.locator('h1')).toContainText(newName);
    
    // Cleanup
    await deleteTestSpace(page, newName);
  });

  test('CRUD-007: Archive space', async ({ page }) => {
    const spaceName = `Archive Test ${Date.now()}`;
    const spaceKey = `AR${Date.now().toString().slice(-3)}`;

    await createTestSpace(page, spaceName, spaceKey);
    
    await page.click('[data-testid="space-menu-button"]');
    await page.click('[data-testid="archive-space-option"]');
    await page.click('[data-testid="confirm-archive-button"]');
    
    await expect(page.locator('[data-testid="toast"]')).toContainText('archived');
    
    // Verify space shows archived status
    await page.goto(`${BASE_URL}/spaces`);
    await page.click('[data-testid="show-archived-toggle"]');
    const archivedSpace = page.locator(`[data-testid="space-card"]:has-text("${spaceName}")`);
    await expect(archivedSpace.locator('[data-testid="archived-badge"]')).toBeVisible();
  });
});

