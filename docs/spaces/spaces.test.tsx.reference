// MOCK DATA
// ============================================================================

const mockUser = {
  id: 'user-123',
  email: 'test@catalyst.gov.sa',
};

const mockSpace = {
  id: 'space-123',
  name: 'Test Space',
  key: 'TST',
  type: 'scrum',
  status: 'active',
  description: 'Test description',
  owner_id: 'user-123',
  created_at: '2025-01-01T00:00:00Z',
  updated_at: '2025-01-01T00:00:00Z',
};

const mockSpaces = [
  mockSpace,
  { ...mockSpace, id: 'space-456', name: 'Another Space', key: 'ANT' },
];

const mockMember = {
  id: 'member-123',
  space_id: 'space-123',
  user_id: 'user-456',
  role: 'member',
  joined_at: '2025-01-01T00:00:00Z',
};

// ============================================================================
// TEST UTILITIES
// ============================================================================

function createWrapper() {
  const queryClient = new QueryClient({
    defaultOptions: {
      queries: { retry: false },
      mutations: { retry: false },
    },
  });
  
  return ({ children }: { children: ReactNode }) => (
    <QueryClientProvider client={queryClient}>
      {children}
    </QueryClientProvider>
  );
}

// ============================================================================
// VALIDATION TESTS
// ============================================================================

describe('Validation Utils', () => {
  describe('validateSpaceName', () => {
    it('should reject empty name', () => {
      const result = validateSpaceName('');
      expect(result.valid).toBe(false);
      expect(result.error).toContain('required');
    });

    it('should reject name shorter than 3 characters', () => {
      const result = validateSpaceName('ab');
      expect(result.valid).toBe(false);
      expect(result.error).toContain('3 characters');
    });

    it('should reject name longer than 255 characters', () => {
      const longName = 'a'.repeat(256);
      const result = validateSpaceName(longName);
      expect(result.valid).toBe(false);
      expect(result.error).toContain('255 characters');
    });

    it('should accept valid name', () => {
      const result = validateSpaceName('Valid Space Name');
      expect(result.valid).toBe(true);
      expect(result.error).toBeUndefined();
    });

    it('should trim whitespace', () => {
      const result = validateSpaceName('  Valid Name  ');
      expect(result.valid).toBe(true);
    });
  });

  describe('validateSpaceKey', () => {
    it('should reject empty key', () => {
      const result = validateSpaceKey('');
      expect(result.valid).toBe(false);
      expect(result.error).toContain('required');
    });

    it('should reject key shorter than 2 characters', () => {
      const result = validateSpaceKey('A');
      expect(result.valid).toBe(false);
      expect(result.error).toContain('2 characters');
    });

    it('should reject key longer than 10 characters', () => {
      const result = validateSpaceKey('VERYLONGKEY');
      expect(result.valid).toBe(false);
      expect(result.error).toContain('10 characters');
    });

    it('should reject key with special characters', () => {
      const result = validateSpaceKey('AB-C');
      expect(result.valid).toBe(false);
      expect(result.error).toContain('alphanumeric');
    });

    it('should reject key with spaces', () => {
      const result = validateSpaceKey('AB C');
      expect(result.valid).toBe(false);
    });

    it('should accept valid key', () => {
      const result = validateSpaceKey('TST');
      expect(result.valid).toBe(true);
    });

    it('should uppercase key', () => {
      const result = validateSpaceKey('tst');
      expect(result.valid).toBe(true);
      expect(result.value).toBe('TST');
    });
  });

  describe('validateVersionDates', () => {
    it('should reject end date before start date', () => {
      const result = validateVersionDates('2025-06-01', '2025-05-01');
      expect(result.valid).toBe(false);
      expect(result.error).toContain('after start');
    });

    it('should accept end date same as start date', () => {
      const result = validateVersionDates('2025-06-01', '2025-06-01');
      expect(result.valid).toBe(true);
    });

    it('should accept end date after start date', () => {
      const result = validateVersionDates('2025-05-01', '2025-06-01');
      expect(result.valid).toBe(true);
    });
  });
});

// Validation functions (would be imported from actual file)
function validateSpaceName(name: string) {
  const trimmed = name.trim();
  if (!trimmed) return { valid: false, error: 'Name is required' };
  if (trimmed.length < 3) return { valid: false, error: 'Name must be at least 3 characters' };
  if (trimmed.length > 255) return { valid: false, error: 'Name must be at most 255 characters' };
  return { valid: true, value: trimmed };
}

function validateSpaceKey(key: string) {
  const trimmed = key.trim().toUpperCase();
  if (!trimmed) return { valid: false, error: 'Key is required' };
  if (trimmed.length < 2) return { valid: false, error: 'Key must be at least 2 characters' };
  if (trimmed.length > 10) return { valid: false, error: 'Key must be at most 10 characters' };
  if (!/^[A-Z0-9]+$/.test(trimmed)) return { valid: false, error: 'Key must be alphanumeric only' };
  return { valid: true, value: trimmed };
}

function validateVersionDates(startDate: string, endDate: string) {
  const start = new Date(startDate);
  const end = new Date(endDate);
  if (end < start) return { valid: false, error: 'End date must be after start date' };
  return { valid: true };
}

// ============================================================================
// SERVICE TESTS
// ============================================================================

describe('SpaceService', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe('getSpaces', () => {
    it('should return paginated spaces', async () => {
      const { supabase } = await import('@/lib/supabase');
      
      const result = await getSpaces({ page: 1, limit: 10 });
      
      expect(supabase.from).toHaveBeenCalledWith('spaces');
      expect(result.data).toHaveLength(2);
    });

    it('should filter by type', async () => {
      const { supabase } = await import('@/lib/supabase');
      
      await getSpaces({ page: 1, limit: 10, type: 'scrum' });
      
      // Verify filter was applied
      expect(supabase.from).toHaveBeenCalledWith('spaces');
    });

    it('should handle errors', async () => {
      const { supabase } = await import('@/lib/supabase');
      vi.mocked(supabase.from).mockImplementationOnce(() => ({
        select: vi.fn(() => ({
          order: vi.fn(() => ({
            range: vi.fn(() => Promise.resolve({ data: null, error: { message: 'Error' } })),
          })),
        })),
      } as any));
      
      await expect(getSpaces({ page: 1, limit: 10 })).rejects.toThrow();
    });
  });

  describe('getSpace', () => {
    it('should return single space by id', async () => {
      const result = await getSpace('space-123');
      
      expect(result).toEqual(mockSpace);
    });

    it('should throw on not found', async () => {
      const { supabase } = await import('@/lib/supabase');
      vi.mocked(supabase.from).mockImplementationOnce(() => ({
        select: vi.fn(() => ({
          eq: vi.fn(() => ({
            single: vi.fn(() => Promise.resolve({ data: null, error: { code: 'PGRST116' } })),
          })),
        })),
      } as any));
      
      await expect(getSpace('invalid')).rejects.toThrow();
    });
  });

  describe('createSpace', () => {
    it('should create space with valid data', async () => {
      const data = { name: 'New Space', key: 'NEW', type: 'scrum' };
      
      const result = await createSpace(data);
      
      expect(result).toEqual(mockSpace);
    });

    it('should reject duplicate key', async () => {
      const { supabase } = await import('@/lib/supabase');
      vi.mocked(supabase.from).mockImplementationOnce(() => ({
        insert: vi.fn(() => ({
          select: vi.fn(() => ({
            single: vi.fn(() => Promise.resolve({ 
              data: null, 
              error: { code: '23505', message: 'duplicate key' } 
            })),
          })),
        })),
      } as any));
      
      await expect(createSpace({ name: 'Test', key: 'TST', type: 'scrum' }))
        .rejects.toThrow('duplicate');
    });
  });

  describe('updateSpace', () => {
    it('should update space', async () => {
      const result = await updateSpace('space-123', { name: 'Updated' });
      
      expect(result).toEqual(mockSpace);
    });
  });

  describe('deleteSpace', () => {
    it('should soft delete space', async () => {
      await expect(deleteSpace('space-123')).resolves.not.toThrow();
    });
  });
});

// Service functions (would be imported from actual file)
async function getSpaces(params: { page: number; limit: number; type?: string }) {
  const { supabase } = await import('@/lib/supabase');
  
  let query = supabase.from('spaces').select('*', { count: 'exact' });
  
  if (params.type) {
    query = query.eq('type', params.type);
  }
  
  const { data, error, count } = await query
    .order('created_at', { ascending: false })
    .range((params.page - 1) * params.limit, params.page * params.limit - 1);
  
  if (error) throw new Error(error.message);
  return { data, count };
}

async function getSpace(id: string) {
  const { supabase } = await import('@/lib/supabase');
  
  const { data, error } = await supabase
    .from('spaces')
    .select('*')
    .eq('id', id)
    .single();
  
  if (error) throw new Error(error.message || 'Space not found');
  return data;
}

async function createSpace(data: { name: string; key: string; type: string }) {
  const { supabase } = await import('@/lib/supabase');
  
  const { data: space, error } = await supabase
    .from('spaces')
    .insert(data)
    .select()
    .single();
  
  if (error) {
    if (error.code === '23505') throw new Error('duplicate key');
    throw new Error(error.message);
  }
  return space;
}

async function updateSpace(id: string, data: Partial<{ name: string }>) {
  const { supabase } = await import('@/lib/supabase');
  
  const { data: space, error } = await supabase
    .from('spaces')
    .update(data)
    .eq('id', id)
    .select()
    .single();
  
  if (error) throw new Error(error.message);
  return space;
}

async function deleteSpace(id: string) {
  const { supabase } = await import('@/lib/supabase');
  
  const { error } = await supabase
    .from('spaces')
    .delete()
    .eq('id', id);
  
  if (error) throw new Error(error.message);
}

// ============================================================================
// HOOK TESTS
// ============================================================================

describe('useSpaces Hook', () => {
  it('should fetch spaces', async () => {
    const { result } = renderHook(
      () => useSpaces({ page: 1, limit: 10 }),
      { wrapper: createWrapper() }
    );

    await waitFor(() => expect(result.current.isSuccess).toBe(true));

    expect(result.current.data?.data).toHaveLength(2);
  });

  it('should handle loading state', () => {
    const { result } = renderHook(
      () => useSpaces({ page: 1, limit: 10 }),
      { wrapper: createWrapper() }
    );

    expect(result.current.isLoading).toBe(true);
  });
});

describe('useSpace Hook', () => {
  it('should fetch single space', async () => {
    const { result } = renderHook(
      () => useSpace('space-123'),
      { wrapper: createWrapper() }
    );

    await waitFor(() => expect(result.current.isSuccess).toBe(true));

    expect(result.current.data).toEqual(mockSpace);
  });
});

describe('useCreateSpace Hook', () => {
  it('should create space and invalidate cache', async () => {
    const { result } = renderHook(
      () => useCreateSpace(),
      { wrapper: createWrapper() }
    );

    await act(async () => {
      await result.current.mutateAsync({
        name: 'New Space',
        key: 'NEW',
        type: 'scrum',
      });
    });

    expect(result.current.isSuccess).toBe(true);
  });
});

// Hook implementations (would be imported from actual file)
function useSpaces(params: { page: number; limit: number }) {
  const { useQuery } = require('@tanstack/react-query');
  
  return useQuery({
    queryKey: ['spaces', params],
    queryFn: () => getSpaces(params),
  });
}

function useSpace(id: string) {
  const { useQuery } = require('@tanstack/react-query');
  
  return useQuery({
    queryKey: ['space', id],
    queryFn: () => getSpace(id),
    enabled: !!id,
  });
}

function useCreateSpace() {
  const { useMutation, useQueryClient } = require('@tanstack/react-query');
  const queryClient = useQueryClient();
  
  return useMutation({
    mutationFn: createSpace,
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['spaces'] });
    },
  });
}

// ============================================================================
// STORE TESTS
// ============================================================================

describe('SpaceStore (Zustand)', () => {
  beforeEach(() => {
    // Reset store between tests
    useSpaceStore.getState().reset();
  });

  it('should have correct initial state', () => {
    const state = useSpaceStore.getState();
    
    expect(state.currentSpaceId).toBeNull();
    expect(state.sidebarOpen).toBe(true);
    expect(state.view).toBe('grid');
  });

  it('should update currentSpaceId', () => {
    useSpaceStore.getState().setCurrentSpaceId('space-123');
    
    expect(useSpaceStore.getState().currentSpaceId).toBe('space-123');
  });

  it('should toggle sidebar', () => {
    useSpaceStore.getState().toggleSidebar();
    expect(useSpaceStore.getState().sidebarOpen).toBe(false);
    
    useSpaceStore.getState().toggleSidebar();
    expect(useSpaceStore.getState().sidebarOpen).toBe(true);
  });

  it('should change view', () => {
    useSpaceStore.getState().setView('list');
    
    expect(useSpaceStore.getState().view).toBe('list');
  });
});

// Store implementation (would be imported from actual file)
import { create } from 'zustand';

interface SpaceStore {
  currentSpaceId: string | null;
  sidebarOpen: boolean;
  view: 'grid' | 'list';
  setCurrentSpaceId: (id: string | null) => void;
  toggleSidebar: () => void;
  setView: (view: 'grid' | 'list') => void;
  reset: () => void;
}

const useSpaceStore = create<SpaceStore>((set) => ({
  currentSpaceId: null,
  sidebarOpen: true,
  view: 'grid',
  setCurrentSpaceId: (id) => set({ currentSpaceId: id }),
  toggleSidebar: () => set((state) => ({ sidebarOpen: !state.sidebarOpen })),
  setView: (view) => set({ view }),
  reset: () => set({ currentSpaceId: null, sidebarOpen: true, view: 'grid' }),
}));

// ============================================================================
// UTILITY TESTS
// ============================================================================

describe('Utility Functions', () => {
  describe('formatSpaceKey', () => {
    it('should uppercase and trim', () => {
      expect(formatSpaceKey('  abc  ')).toBe('ABC');
    });

    it('should remove invalid characters', () => {
      expect(formatSpaceKey('ab-c')).toBe('ABC');
    });
  });

  describe('getSpaceInitials', () => {
    it('should return first two letters for single word', () => {
      expect(getSpaceInitials('Project')).toBe('PR');
    });

    it('should return first letter of first two words', () => {
      expect(getSpaceInitials('Test Space')).toBe('TS');
    });

    it('should handle empty string', () => {
      expect(getSpaceInitials('')).toBe('??');
    });
  });

  describe('canUserPerformAction', () => {
    it('should allow owner to delete', () => {
      expect(canUserPerformAction('owner', 'space.delete')).toBe(true);
    });

    it('should not allow member to delete', () => {
      expect(canUserPerformAction('member', 'space.delete')).toBe(false);
    });

    it('should allow viewer to view', () => {
      expect(canUserPerformAction('viewer', 'space.view')).toBe(true);
    });

    it('should not allow viewer to edit', () => {
      expect(canUserPerformAction('viewer', 'space.edit')).toBe(false);
    });
  });
});

// Utility functions (would be imported from actual file)
function formatSpaceKey(key: string): string {
  return key.trim().toUpperCase().replace(/[^A-Z0-9]/g, '');
}

function getSpaceInitials(name: string): string {
  if (!name) return '??';
  const words = name.trim().split(/\s+/);
  if (words.length === 1) {
    return words[0].slice(0, 2).toUpperCase();
  }
  return (words[0][0] + words[1][0]).toUpperCase();
}

const PERMISSIONS = {
  'space.view': ['owner', 'lead', 'member', 'viewer'],
  'space.edit': ['owner', 'lead'],
  'space.delete': ['owner'],
  'members.add': ['owner', 'lead'],
  'members.remove': ['owner', 'lead'],
  'settings.edit': ['owner', 'lead'],
};

function canUserPerformAction(role: string, action: string): boolean {
  const allowedRoles = PERMISSIONS[action as keyof typeof PERMISSIONS] || [];
  return allowedRoles.includes(role);
}

