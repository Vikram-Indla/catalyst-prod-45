{
  "version": "1.0.0",
  "designSystem": "Atlassian Design System v4",
  "tokens": {
    "typography": {
      "heading": {
        "h1": { "fontSize": "28px", "fontWeight": "600", "lineHeight": "1.2" },
        "h2": { "fontSize": "20px", "fontWeight": "600", "lineHeight": "1.25" },
        "h3": { "fontSize": "16px", "fontWeight": "600", "lineHeight": "1.5" }
      },
      "body": {
        "default": { "fontSize": "14px", "fontWeight": "400", "lineHeight": "1.5" },
        "small": { "fontSize": "12px", "fontWeight": "400", "lineHeight": "1.5" }
      }
    },
    "spacing": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px"
    },
    "colors": {
      "primary": "var(--ds-background-information-bold)",
      "danger": "var(--ds-background-danger-bold)",
      "success": "var(--ds-background-success-bold)",
      "warning": "var(--ds-background-warning-bold)"
    }
  },
  "banned": {
    "components": ["Story Points", "MDT Ref", "Assessment Feature", "Service Now#"],
    "patterns": ["text-transform: uppercase on labels", "hardcoded px spacing", "raw hex colors"],
    "columns": ["Type (standalone)", "Category", "Space URL", "Templates"]
  },
  "required": {
    "components": ["@atlaskit/dropdown-menu", "@atlaskit/select", "@atlaskit/modal-dialog"],
    "accessibility": ["WCAG 2.1 AA", "role attributes", "aria-labels"]
  }
}
